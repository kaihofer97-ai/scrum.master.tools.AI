<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ScrumFlow Hub - Interactive Scrum Master Toolkit</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <script>
    // Initialize namespace
    window.ScrumHub = {
      state: {},
      modules: {}
    };
  </script>

  <div class="app-container">
    <!-- Sidebar Navigation -->
    <aside class="sidebar">
      <div>
        <div class="sidebar-logo">
          <!-- Logo Icon (Infinity/Scrum loop) -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
            <path d="M12 6v6l4 2"/>
          </svg>
          <span class="logo-text">ScrumFlow</span>
        </div>
        <nav>
          <ul class="nav-list">
            <li class="nav-item active" data-target="capacity-view">
              <button>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <line x1="9" y1="9" x2="15" y2="9"/>
                  <line x1="9" y1="13" x2="15" y2="13"/>
                  <line x1="9" y1="17" x2="15" y2="17"/>
                  <line x1="12" y1="6" x2="12" y2="18"/>
                </svg>
                Capacity Calc
              </button>
            </li>
            <li class="nav-item" data-target="standup-view">
              <button>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                Standup Wheel
              </button>
            </li>
            <li class="nav-item" data-target="retro-view">
              <button>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <line x1="3" y1="9" x2="21" y2="9"/>
                  <line x1="9" y1="21" x2="9" y2="9"/>
                </svg>
                Retro Board
              </button>
            </li>
            <li class="nav-item" data-target="poker-view">
              <button>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <path d="M7 7h10M7 12h10M7 17h10"/>
                </svg>
                Planning Poker
              </button>
            </li>
            <li class="nav-item" data-target="generator-view">
              <button>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="16" y1="13" x2="8" y2="13"/>
                  <line x1="16" y1="17" x2="8" y2="17"/>
                  <polyline points="10 9 9 9 8 9"/>
                </svg>
                Jira & Release Gen
              </button>
            </li>
          </ul>
        </nav>
      </div>
      <div class="sidebar-footer">
        <div><strong>ScrumFlow Hub</strong> v1.0</div>
        <div>Offline & Zero-Setup Active</div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      
      <!-- 1. Capacity Calculator View -->
      <section id="capacity-view" class="view-section active">
        <div class="view-header">
          <div class="view-header-info">
            <h2>Sprint Capacity Calculator</h2>
            <p>Calculate your team's total available capacity in hours and estimated story points.</p>
          </div>
        </div>

        <div class="grid-sidebar-layout">
          <!-- Team Inputs Table -->
          <div class="card glass">
            <div class="card-title">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              Team Availability
            </div>
            
            <div class="capacity-table-wrapper">
              <table class="capacity-table" id="capacityTable">
                <thead>
                  <tr>
                    <th>Team Member</th>
                    <th>Role</th>
                    <th>Daily Hrs</th>
                    <th>Days Off/PTO</th>
                    <th>Focus Factor %</th>
                    <th>Net Capacity</th>
                    <th>Action</th>
                  </tr>
                </thead>
                <tbody id="capacityTableBody">
                  <!-- Generated via JS -->
                </tbody>
              </table>
            </div>

            <div style="display: flex; gap: 1rem;">
              <button class="btn btn-secondary" id="addMemberBtn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Member
              </button>
              <button class="btn btn-secondary" id="resetCapacityBtn">Reset Table</button>
            </div>
          </div>

          <!-- Configuration & Summary -->
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="card glass">
              <div class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                Sprint Settings
              </div>
              <div class="form-group">
                <label class="form-label" for="sprintDays">Sprint Duration (Working Days)</label>
                <input class="input-control" type="number" id="sprintDays" value="10" min="1">
              </div>
              <div class="form-group">
                <label class="form-label" for="historicalVelocity">Historical Velocity (Story Points)</label>
                <input class="input-control" type="number" id="historicalVelocity" value="30" min="0">
              </div>
              <div class="form-group">
                <label class="form-label" for="historicalCapacity">Historical Capacity (Hours used in previous sprint)</label>
                <input class="input-control" type="number" id="historicalCapacity" value="280" min="1">
              </div>
            </div>

            <div class="card glass" style="border-color: var(--color-primary-glow);">
              <div class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                Capacity Metrics
              </div>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div>
                  <div class="capacity-summary-val" id="totalHoursVal">0</div>
                  <div class="capacity-summary-lbl">Total Capacity Hours</div>
                </div>
                <div>
                  <div class="capacity-summary-val" id="estimatedPointsVal" style="color: var(--color-primary);">0</div>
                  <div class="capacity-summary-lbl">Est. Story Points</div>
                </div>
              </div>
              <div style="margin-top: 0.5rem; font-size: 0.85rem; color: var(--text-muted); border-top: 1px solid var(--border-color); padding-top: 0.75rem;">
                Estimated Story Points are calculated using your historical velocity ratio (Story Points per Hour).
              </div>
              <button class="btn btn-primary" id="copyCapacitySummaryBtn" style="margin-top: 0.5rem;">
                Copy Capacity Summary
              </button>
            </div>
          </div>
        </div>
      </section>

      <!-- 2. Daily Standup Facilitator View -->
      <section id="standup-view" class="view-section">
        <div class="view-header">
          <div class="view-header-info">
            <h2>Daily Standup Facilitator</h2>
            <p>Ensure quick, fair, and timed daily standup updates. Spin the wheel to select the next speaker.</p>
          </div>
        </div>

        <div class="grid-sidebar-layout">
          <!-- Spinning Wheel Panel -->
          <div class="card glass" style="align-items: center; justify-content: center;">
            <div class="wheel-container">
              <div class="canvas-wrapper">
                <div class="wheel-pointer"></div>
                <div class="wheel-center-pin"></div>
                <canvas id="wheelCanvas" width="320" height="320"></canvas>
              </div>
              <div class="standup-actions">
                <button class="btn btn-primary" id="spinWheelBtn">Spin Wheel</button>
                <button class="btn btn-secondary" id="resetStandupBtn">Reset Speaker List</button>
              </div>
              <div id="activeSpeakerBanner" class="active-speaker-banner" style="display: none;">
                Next up: <span id="activeSpeakerName">Name</span>!
              </div>
            </div>
          </div>

          <!-- Standup Timer & Team Settings -->
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <!-- Timer Widget -->
            <div class="card glass timer-widget">
              <div class="card-title" style="margin-bottom: 0.25rem;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Speaker Timer
              </div>
              <div class="timer-circle" id="timerCircle">
                <div class="timer-display" id="timerDisplay">01:00</div>
              </div>
              <div style="display: flex; gap: 0.5rem; justify-content: center;">
                <button class="btn btn-secondary btn-icon-only" id="timerToggleBtn" title="Start/Pause Timer">
                  <!-- Play Icon -->
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </button>
                <button class="btn btn-secondary btn-icon-only" id="timerResetBtn" title="Reset Timer">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                </button>
              </div>
              <div class="form-group" style="width: 100%; margin-top: 0.5rem;">
                <label class="form-label" for="timerDuration">Timer Limits (seconds)</label>
                <input class="input-control" type="number" id="timerDuration" value="60" min="5">
              </div>
            </div>

            <!-- Speaker / Team List Manage -->
            <div class="card glass">
              <div class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                Standup Attendees
              </div>
              <div class="form-group" style="flex-direction: row; gap: 0.5rem;">
                <input class="input-control" type="text" id="newAttendeeInput" placeholder="Attendee Name..." style="flex-grow: 1;">
                <button class="btn btn-secondary" id="addAttendeeBtn">Add</button>
              </div>
              <div class="team-members-chips" id="attendeesChips">
                <!-- Managed via JS -->
              </div>
            </div>

            <!-- Blocker Tracker -->
            <div class="card glass">
              <div class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
                Standup Blockers Scratchpad
              </div>
              <textarea class="input-control" id="blockerScratchpad" placeholder="Write down blocker items here (e.g. &#10;- Dave: API endpoint delayed&#10;- Sarah: Needs design review)"></textarea>
              <button class="btn btn-secondary" id="copyBlockersBtn">Copy Blockers</button>
            </div>
          </div>
        </div>
      </section>

      <!-- 3. Sprint Retrospective Board View -->
      <section id="retro-view" class="view-section">
        <div class="view-header">
          <div class="view-header-info">
            <h2>Sprint Retrospective Board</h2>
            <p>Gather feedback, vote on items, and establish team improvement action items.</p>
          </div>
          <div style="display: flex; gap: 1rem; align-items: center;">
            <div class="form-group" style="flex-direction: row; align-items: center; gap: 0.5rem; margin-bottom: 0;">
              <label class="form-label" for="retroTemplateSelect" style="white-space: nowrap;">Template:</label>
              <select class="select-control" id="retroTemplateSelect" style="padding: 0.5rem 2rem 0.5rem 1rem;">
                <option value="start-stop-continue">Start / Stop / Continue</option>
                <option value="glad-sad-mad">Glad / Sad / Mad</option>
                <option value="four-ls">4Ls (Liked, Learned, Lacked, Longed For)</option>
              </select>
            </div>
            <button class="btn btn-primary" id="exportRetroBtn">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Export Board (MD)
            </button>
            <button class="btn btn-danger" id="clearRetroBtn">Clear Board</button>
          </div>
        </div>

        <!-- Sticky Card Creator Form -->
        <div class="card glass" style="flex-direction: row; align-items: flex-end; gap: 1rem; flex-wrap: wrap;">
          <div class="form-group" style="flex-grow: 2; min-width: 250px;">
            <label class="form-label" for="retroCardTextInput">Feedback Description</label>
            <input class="input-control" type="text" id="retroCardTextInput" placeholder="What is on your mind?">
          </div>
          <div class="form-group" style="flex-grow: 1; min-width: 150px;">
            <label class="form-label" for="retroCardColumnSelect">Target Column</label>
            <select class="select-control" id="retroCardColumnSelect">
              <!-- Dynamically populated based on template -->
            </select>
          </div>
          <div class="form-group" style="flex-grow: 1; min-width: 150px;">
            <label class="form-label" for="retroCardColorSelect">Color Theme</label>
            <select class="select-control" id="retroCardColorSelect">
              <option value="cyan">Indigo-Cyan</option>
              <option value="purple">Aura-Purple</option>
              <option value="emerald">Growth-Green</option>
              <option value="amber">Warm-Orange</option>
            </select>
          </div>
          <button class="btn btn-primary" id="addRetroCardBtn" style="height: 42px;">Add Sticky</button>
        </div>

        <!-- Retro Columns -->
        <div class="retro-columns-container" id="retroColumnsContainer">
          <!-- Populated via JS -->
        </div>
      </section>

      <!-- 4. Planning Poker Simulator View -->
      <section id="poker-view" class="view-section">
        <div class="view-header">
          <div class="view-header-info">
            <h2>Interactive Planning Poker</h2>
            <p>Select a deck, cast your estimate card, and let artificial team members simulate a planning session.</p>
          </div>
        </div>

        <div class="poker-setup" id="pokerSetupScreen">
          <div class="card glass">
            <div class="card-title">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Select Estimating Deck
            </div>
            <div class="poker-deck-selection">
              <div class="deck-chip selected" data-deck="fibonacci">
                <h3>Fibonacci</h3>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 0.25rem;">0, 1, 2, 3, 5, 8, 13, 21, ?</p>
              </div>
              <div class="deck-chip" data-deck="tshirt">
                <h3>T-Shirt</h3>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 0.25rem;">XS, S, M, L, XL, ?</p>
              </div>
              <div class="deck-chip" data-deck="standard">
                <h3>Standard Cards</h3>
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-top: 0.25rem;">1, 2, 3, 4, 5, 8, 10, ?</p>
              </div>
            </div>

            <div class="form-group" style="margin-top: 1rem;">
              <label class="form-label" for="pokerStoryDifficulty">Simulated Story Complexity</label>
              <select class="select-control" id="pokerStoryDifficulty">
                <option value="simple">Simple Task (Likely 1 - 3 points)</option>
                <option value="medium">Medium Complexity (Likely 3 - 8 points)</option>
                <option value="complex">High Complexity (Likely 8 - 21 points)</option>
                <option value="wildcard">Wildcard / Disagreed (Mix of different estimations)</option>
              </select>
            </div>

            <button class="btn btn-primary" id="startPokerSessionBtn">Start Planning Session</button>
          </div>
        </div>

        <div class="poker-layout" id="pokerSessionScreen" style="display: none;">
          <!-- Left side: Deck cards selector -->
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="card glass">
              <div class="card-title">
                Choose Your Card
              </div>
              <div class="poker-cards-grid" id="pokerCardsGrid">
                <!-- Cards will render here -->
              </div>
              <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button class="btn btn-accent" id="pokerRevealBtn" disabled>Reveal Votes</button>
                <button class="btn btn-secondary" id="pokerNextBtn">Next Story / Reset</button>
                <button class="btn btn-secondary" id="pokerBackToSetupBtn">Change Deck</button>
              </div>
            </div>
          </div>

          <!-- Right side: Planning Table & Metrics -->
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="card glass poker-table-simulator">
              <div class="card-title">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
                Planning Table Simulator
              </div>
              
              <div class="poker-seats" id="pokerSeats">
                <!-- User and simulated team seats -->
              </div>

              <!-- Metrics -->
              <div class="poker-stats">
                <div>
                  <div class="capacity-summary-val" id="pokerAvgVal" style="font-size: 1.75rem;">-</div>
                  <div class="capacity-summary-lbl" style="font-size: 0.75rem;">Average</div>
                </div>
                <div>
                  <div class="capacity-summary-val" id="pokerConsensusVal" style="color: var(--color-primary); font-size: 1.75rem;">-</div>
                  <div class="capacity-summary-lbl" style="font-size: 0.75rem;">Consensus</div>
                </div>
                <div>
                  <div class="capacity-summary-val" id="pokerActionVal" style="color: var(--color-warning); font-size: 1.75rem;">-</div>
                  <div class="capacity-summary-lbl" style="font-size: 0.75rem;">Status</div>
                </div>
              </div>
              
              <div style="font-size: 0.85rem; color: var(--text-muted); text-align: center; border-top: 1px solid var(--border-color); padding-top: 0.75rem;" id="pokerInstructionText">
                Cast your card to prompt estimates from the rest of the team.
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 5. Ticket & Release Notes Generator View -->
      <section id="generator-view" class="view-section">
        <div class="view-header">
          <div class="view-header-info">
            <h2>Jira Ticket & Release Notes Generator</h2>
            <p>Generate professional, standard Jira User Stories, Bug Reports, and Release Notes summaries.</p>
          </div>
        </div>

        <!-- Generator Tabs -->
        <div class="generator-tabs">
          <button class="generator-tab-btn active" data-tab="user-story-form">User Story</button>
          <button class="generator-tab-btn" data-tab="bug-report-form">Bug Report</button>
          <button class="generator-tab-btn" data-tab="release-notes-form">Release Notes</button>
        </div>

        <div class="grid-sidebar-layout">
          <!-- Forms Area -->
          <div class="card glass">
            <!-- Form 1: User Story -->
            <div id="user-story-form" class="generator-form-panel">
              <div class="card-title" style="margin-bottom: 1rem;">User Story Details</div>
              <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                  <label class="form-label" for="usRole">As a...</label>
                  <input class="input-control" type="text" id="usRole" placeholder="e.g. Registered User" value="Product Manager">
                </div>
                <div class="form-group">
                  <label class="form-label" for="usFeature">I want to...</label>
                  <input class="input-control" type="text" id="usFeature" placeholder="e.g. filter transaction history by date range" value="have a dashboard summary of sprint capacity">
                </div>
                <div class="form-group">
                  <label class="form-label" for="usBenefit">So that I can...</label>
                  <input class="input-control" type="text" id="usBenefit" placeholder="e.g. find past payments quickly" value="quickly plan our sprint commitments without error">
                </div>
                <div class="form-group">
                  <label class="form-label" for="usAcceptance">Acceptance Criteria (Given / When / Then)</label>
                  <textarea class="input-control" id="usAcceptance" placeholder="Given...&#10;When...&#10;Then..." style="min-height: 120px;">Given I am on the capacity page
When I enter the team availability and sprint settings
Then I should see the calculated capacity hours and story points update immediately</textarea>
                </div>
              </div>
            </div>

            <!-- Form 2: Bug Report -->
            <div id="bug-report-form" class="generator-form-panel" style="display: none;">
              <div class="card-title" style="margin-bottom: 1rem;">Bug Report Details</div>
              <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div class="form-group">
                  <label class="form-label" for="bugTitle">Bug Title / Summary</label>
                  <input class="input-control" type="text" id="bugTitle" placeholder="e.g. Capacity resets on tab click" value="Capacity resets on tab switch">
                </div>
                <div class="form-group">
                  <label class="form-label" for="bugEnvironment">Environment Details</label>
                  <input class="input-control" type="text" id="bugEnvironment" placeholder="e.g. Production, Chrome 124, iOS 17" value="Staging, macOS Safari / Chrome">
                </div>
                <div class="form-group">
                  <label class="form-label" for="bugSteps">Steps to Reproduce</label>
                  <textarea class="input-control" id="bugSteps" style="min-height: 100px;">1. Go to the Capacity tab
2. Add a team member
3. Click on the Retro tab and click back
4. Observe that the team member is gone</textarea>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                  <div class="form-group">
                    <label class="form-label" for="bugExpected">Expected Behavior</label>
                    <input class="input-control" type="text" id="bugExpected" value="Team capacity data is persisted in localStorage.">
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="bugActual">Actual Behavior</label>
                    <input class="input-control" type="text" id="bugActual" value="Team capacity data resets to default.">
                  </div>
                </div>
              </div>
            </div>

            <!-- Form 3: Release Notes -->
            <div id="release-notes-form" class="generator-form-panel" style="display: none;">
              <div class="card-title" style="margin-bottom: 1rem;">Release Notes Details</div>
              <div style="display: flex; flex-direction: column; gap: 1rem;">
                <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 1rem;">
                  <div class="form-group">
                    <label class="form-label" for="relTitle">Sprint / Release Version</label>
                    <input class="input-control" type="text" id="relTitle" placeholder="e.g. Sprint 24 Release or v1.2.0" value="Sprint 12 Release">
                  </div>
                  <div class="form-group">
                    <label class="form-label" for="relDate">Release Date</label>
                    <input class="input-control" type="date" id="relDate">
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label" for="relSummary">Sprint Goal / Release Summary</label>
                  <textarea class="input-control" id="relSummary" style="min-height: 80px;" placeholder="What did this release achieve?">Focused on implementing the capacity planner and the interactive spinning wheel standup tracker to increase scrum team automation and engagement.</textarea>
                </div>
                <div class="form-group">
                  <label class="form-label" for="relFeatures">New Features (Comma separated)</label>
                  <input class="input-control" type="text" id="relFeatures" placeholder="Feature A, Feature B" value="Standup wheel randomizer, Sound effects integration, Capacity points calculator">
                </div>
                <div class="form-group">
                  <label class="form-label" for="relBugs">Bug Fixes Resolved (Comma separated)</label>
                  <input class="input-control" type="text" id="relBugs" placeholder="Fix ticket A, Fix ticket B" value="Fixed local storage persistence glitch, Adjusted standard card deck Fibonacci sequence layout">
                </div>
              </div>
            </div>
          </div>

          <!-- Preview & Clipboard Area -->
          <div class="card glass generator-output-card">
            <div class="card-title">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
              Formatted Output Preview
            </div>
            
            <div class="generator-output-area" id="generatorOutput">
              <!-- Dynamically rendered templates -->
            </div>

            <button class="btn btn-accent" id="copyGeneratorBtn">
              Copy Formatted Text
            </button>
          </div>
        </div>
      </section>

    </main>
  </div>

